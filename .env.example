# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — only commit .env.example

# OpenRouter API key (from openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Stripe keys (from dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Price IDs (create these in your Stripe dashboard under Products)
STRIPE_PRICE_50=price_your_50_monthly_id
STRIPE_PRICE_100=price_your_100_monthly_id
STRIPE_PRICE_200=price_your_200_monthly_id

# Supabase (from supabase.com — Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-key

# App config
PORT=3000
# Change this in production! Used to sign session-like tokens.
APP_SECRET=change-this-to-a-long-random-string-in-production

# Your app's public URL (used for Stripe redirect URLs)
APP_URL=http://localhost:3000
